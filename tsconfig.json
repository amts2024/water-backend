{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2023",
    "outDir": "./dist",
    "rootDir": "./src",

    "strict": false,
    "skipLibCheck": true,

    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "types": ["node"],

    "forceConsistentCasingInFileNames": true
  },

  "exclude": [
    "node_modules",
    "test",
    "**/*.spec.ts"
  ]
}